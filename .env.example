# ═════════════════════════════════════════════
# QuickFood — Configuration environnement
# ═════════════════════════════════════════════

# ── SÉCURITÉ ──────────────────────────────────
SECRET_KEY=change-moi-en-production-minimum-32-caracteres
ADMIN_PASSWORD=admin123

# ── PAYTECH ───────────────────────────────────
# Récupérer vos clés sur https://paytech.sn → Tableau de bord → Clés API
PAYTECH_API_KEY=votre_api_key_ici
PAYTECH_API_SECRET=votre_api_secret_ici

# Environnement : "test" pour les tests, "prod" pour la production
PAYTECH_ENV=test

# URLs de retour (remplacer par votre domaine en production)
PAYTECH_IPN_URL=http://127.0.0.1:5000/payment/ipn
PAYTECH_SUCCESS_URL=http://127.0.0.1:5000/payment/success
PAYTECH_CANCEL_URL=http://127.0.0.1:5000/payment/cancel
